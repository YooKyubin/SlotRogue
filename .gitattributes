###############################################################################
# SlotRogue Git attributes
#
# Keep repository text normalized to LF and use Unity Smart Merge for serialized
# YAML assets. Local machines still need the unityyamlmerge merge driver configured
# for merge=unityyamlmerge to take effect.
###############################################################################

* text=auto eol=lf

# Source / project text files
*.cs        text eol=lf
*.asmdef    text eol=lf
*.asmref    text eol=lf
*.uxml      text eol=lf
*.uss       text eol=lf
*.json      text eol=lf
*.xml       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.config    text eol=lf
*.props     text eol=lf
*.targets   text eol=lf

# Unity serialized text assets
*.meta               text eol=lf
*.unity              text eol=lf merge=unityyamlmerge
*.prefab             text eol=lf merge=unityyamlmerge
*.asset              text eol=lf merge=unityyamlmerge
*.mat                text eol=lf merge=unityyamlmerge
*.anim               text eol=lf merge=unityyamlmerge
*.controller         text eol=lf merge=unityyamlmerge
*.overrideController text eol=lf merge=unityyamlmerge
*.mask               text eol=lf merge=unityyamlmerge
*.playable           text eol=lf merge=unityyamlmerge
*.lighting           text eol=lf merge=unityyamlmerge
*.renderTexture      text eol=lf merge=unityyamlmerge
*.terrainlayer       text eol=lf merge=unityyamlmerge
*.guiskin            text eol=lf merge=unityyamlmerge
*.physicsMaterial    text eol=lf merge=unityyamlmerge
*.physicMaterial     text eol=lf merge=unityyamlmerge
*.shadergraph        text eol=lf merge=unityyamlmerge
*.shadersubgraph     text eol=lf merge=unityyamlmerge
*.vfx                text eol=lf merge=unityyamlmerge
*.preset             text eol=lf merge=unityyamlmerge

# Shaders
*.shader   text eol=lf
*.hlsl     text eol=lf
*.cginc    text eol=lf
*.compute  text eol=lf
*.raytrace text eol=lf

# Scripts
*.ps1 text eol=lf
*.sh  text eol=lf
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary assets must not be line-ending normalized.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.psd binary
*.ai binary
*.tga binary
*.bmp binary
*.exr binary
*.hdr binary
*.mp3 binary
*.wav binary
*.ogg binary
*.aif binary
*.aiff binary
*.flac binary
*.m4a binary
*.mp4 binary
*.mov binary
*.avi binary
*.webm binary
*.m4v binary
*.fbx binary
*.obj binary
*.dae binary
*.3ds binary
*.max binary
*.blend binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.dll binary
*.so binary
*.dylib binary
*.bundle binary
*.aar binary
*.jar binary
*.unitypackage binary
*.apk binary
*.aab binary
